                    rml:termType rml:IRI ] ;
            rml:objectMap [ rml:template "http://www.department{departmentnr}.university{universitynr}.edu" ;
                    rml:termType rml:IRI ] ;
            rml:predicateMap [ rml:constant ub:subOrganizationOf ;
                    rml:termType rml:IRI ] ],
        [ rml:graphMap [ rml:constant rml:defaultGraph ;
                    rml:termType rml:IRI ] ;
            rml:objectMap [ rml:constant ub:ResearchGroup ;
                    rml:termType rml:IRI ] ;
