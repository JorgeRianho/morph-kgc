                    rml:termType rml:IRI ] ] ;
    rml:subjectMap [ rml:template "http://www.department{departmentnr}.university{universitynr}.edu/{graduatestudentname}" ;
            rml:termType rml:IRI ] .

<file:///home/jorge/proyectos/git/lubm4obda/mappings/rml/lubm4obda.rml.ttl#GraduateStudentTeachingAssistant> rml:logicalSource [ rml:query """
