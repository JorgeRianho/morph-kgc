                    rml:termType rml:IRI ] ;
            rml:predicateMap [ rml:constant rdf:type ;
                    rml:termType rml:IRI ] ],
        [ rml:graphMap [ rml:constant rml:defaultGraph ;
                    rml:termType rml:IRI ] ;
            rml:objectMap [ rml:reference "undergraduatecoursename" ;
                    rml:termType rml:Literal ] ;
            rml:predicateMap [ rml:constant ub:name ;
                    rml:termType rml:IRI ] ] ;
    rml:subjectMap [ rml:template "http://www.department{departmentnr}.university{universitynr}.edu/{undergraduatecoursename}" ;
            rml:termType rml:IRI ] .

