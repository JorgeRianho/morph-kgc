        [ rml:graphMap [ rml:constant rml:defaultGraph ;
                    rml:termType rml:IRI ] ;
            rml:objectMap [ rml:reference "publicationname" ;
                    rml:termType rml:Literal ] ;
            rml:predicateMap [ rml:constant ub:name ;
                    rml:termType rml:IRI ] ],
        [ rml:graphMap [ rml:constant rml:defaultGraph ;
                    rml:termType rml:IRI ] ;
            rml:objectMap [ rml:reference "publicationtitle" ;
                    rml:termType rml:Literal ] ;
            rml:predicateMap [ rml:constant ub:title ;
                    rml:termType rml:IRI ] ],
        [ rml:graphMap [ rml:constant rml:defaultGraph ;
                    rml:termType rml:IRI ] ;
            rml:objectMap [ rml:constant ub:Publication ;
